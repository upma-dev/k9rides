# Server Configuration
PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=k9

MONGODB_DB_NAME=K9

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES=30d


# Frontend URL (for CORS)
FRONTEND_URL=https://k9rides.onrender.com,https://K9 Rides.com


# Realtime & Queue Configuration
# Redis Configuration - Set REDIS_ENABLED=true to use Redis caching
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
BULLMQ_ENABLED=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=120
BCRYPT_SALT_ROUNDS=10
UPLOAD_PATH=uploads/

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# Email Configuration (if using email service)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="K9 Rides <noreply@example.com>"


# Google Maps API Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Admin registration safeguard
ADMIN_REGISTRATION_CODE=secure-code-to-create-admins
ADMIN_NOTIFICATION_EMAILS=admin1@example.com,admin2@example.com


#Test Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=


# Password reset configuration
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# Socket.io Configuration
SOCKET_CORS_ORIGIN=https://k9rides.onrender.com


# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.


FIREBASE_SERVICE_ACCOUNT='{
  "type": "service_account",
  "project_id": "your-project-id",
  "private_key_id": "your_private_key_id",
  "private_key": "-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n",
  "client_email": "firebase-adminsdk-fbsvc@your-project-id.iam.gserviceaccount.com",
  "client_id": "your_client_id",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40your-project-id.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"}'

VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.asia-southeast1.firebasedatabase.app/



# ========================================
# SMS INDIA HUB CONFIGURATION
# ========================================
# Get these from your SMS India Hub account
# Set to 'true' to use default OTP (1234) for testing (development only)
# Set to 'false' in production!
USE_DEFAULT_OTP=true
STATIC_OTP_PHONE=8770552411
STATIC_OTP_CODE=1234

SMS_INDIA_HUB_USERNAME=your_sms_username
# SMS_INDIA_HUB_PASSWORD=your_sms_password
SMS_INDIA_HUB_API_KEY=your_sms_api_key
SMS_INDIA_HUB_SENDER_ID=IIDMTB
SMS_INDIA_HUB_DLT_TEMPLATE_ID=your_dlt_template_id
# ========================================
# OTP CONFIGURATION (PRODUCTION VALUES)
# ========================================
OTP_EXPIRY_MINUTES=10
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW=600
OTP_EXPIRY=5m

# Extra keys kept from existing env
DRIVER_WALLET_DEFAULT_CASH_LIMIT=500
DRIVER_COMMISSION_PERCENT=20
# CLOUDINARY_FOLDER=k9

# Petpooja POS Integration
PETPOOJA_ENABLED=true
PETPOOJA_API_KEY=test_key
PETPOOJA_CLIENT_CODE=test_client
PETPOOJA_OUTLET_ID=test_outlet
PETPOOJA_API_URL=https://api.petpooja.com/v2

DEPLOY_WEBHOOK_SECRET=your_webhook_secret
